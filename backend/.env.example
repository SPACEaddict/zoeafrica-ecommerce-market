# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5000

# ── MongoDB (free at mongodb.com/atlas) ──────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/zoeafrica

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_random_chars
JWT_EXPIRE=30d

# ── Cloudinary (free at cloudinary.com) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=zoeafrica-ecommerce
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr.zoeafrica@gmail.com
SMTP_PASS=Genius@254

# ── M-Pesa Kenya (developer.safaricom.co.ke) ─────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_key
MPESA_CONSUMER_SECRET=your_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey

# ── M-Pesa Africa (openapiportal.m-pesa.com) ─────────────────────────────────
MPESA_AFRICA_API_KEY=your_key
MPESA_AFRICA_PUBLIC_KEY=your_public_key
MPESA_AFRICA_SERVICE_CODE=your_service_code

# ── Paystack (paystack.com) ───────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
